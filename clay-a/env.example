# Host port for Clay A
CLAY_A_PORT=8089

# Required: Your OpenAI API key
OPENAI_API_KEY="sk-your-openai-api-key-here"

# Optional: Expected Anthropic API key for client validation
# If set, clients must provide this exact API key to access the proxy
ANTHROPIC_API_KEY="your-expected-anthropic-api-key"

# Optional: OpenAI API base URL (default: https://api.openai.com/v1)
# You can change this to use Azure OpenAI if needed.
OPENAI_BASE_URL="https://api.openai.com/v1"

# Optional: Temperature mapping compatibility knob
# false (default): forward Anthropic temperature as-is
# true: multiply Anthropic temperature by 2 before sending upstream
ANTHROPIC_TEMPERATURE_SCALE_TO_OPENAI_X2="false"

# Optional: GPT-5 sampling/reasoning compatibility strategy
# off: no compatibility handling
# drop_sampling (default): remove temperature/top_p when reasoning effort is non-none
# force_reasoning_none: keep sampling fields, force reasoning.effort='none'
# strict_error: reject conflicting requests with 400
OPENAI_GPT5_SAMPLING_REASONING_COMPAT_MODE="drop_sampling"

# Optional: Model mappings (BIG and SMALL models)
BIG_MODEL="gpt-5.3-codex"
# Used for Claude opus requests
MIDDLE_MODEL="gpt-5.3-codex"
# Used for Claude sonnet requests
SMALL_MODEL="gpt-5.3-codex"
# Used for Claude haiku requests

# Optional: Server settings
HOST="0.0.0.0"
PORT="8000"
LOG_LEVEL="INFO"  
# DEBUG, INFO, WARNING, ERROR, CRITICAL
UVICORN_WORKERS="4"
# Uvicorn worker process count (1 or higher)

# Optional: Performance settings  
MAX_TOKENS_LIMIT="4096"
# Minimum tokens limit for requests (to avoid errors with thinking model)
MIN_TOKENS_LIMIT="100"
REQUEST_TIMEOUT="90"
MAX_RETRIES="2"

# Examples for other providers:

# For Azure OpenAI (recommended if OpenAI is not available in your region):
# OPENAI_API_KEY="your-azure-api-key"
# OPENAI_BASE_URL="https://your-resource-name.openai.azure.com/openai/deployments/your-deployment-name"
# AZURE_API_VERSION="2024-03-01-preview"
# BIG_MODEL="gpt-4"
# MIDDLE_MODEL="gpt-4"
# SMALL_MODEL="gpt-35-turbo"

# Note: If you get "unsupported_country_region_territory" errors,
# consider using Azure OpenAI setup instead.
