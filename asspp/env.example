# Host port for AssppWeb
ASSPP_PORT=8086

# Optional public base URL for install manifests (example: https://asspp.example.com)
ASSPP_PUBLIC_BASE_URL=

# Optional: set true only when your reverse proxy cannot send X-Forwarded-Proto correctly.
ASSPP_DISABLE_HTTPS_REDIRECT=false

# Optional cleanup and resource controls
ASSPP_AUTO_CLEANUP_DAYS=0
ASSPP_AUTO_CLEANUP_MAX_MB=0
ASSPP_MAX_DOWNLOAD_MB=0
ASSPP_DOWNLOAD_THREADS=8

# Optional: require a password for the AssppWeb UI/API (empty disables auth)
ASSPP_ACCESS_PASSWORD=
