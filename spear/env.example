# Beacon Spear — deployment environment variables
# cp env.example .env && chmod 600 .env
# Then fill in real values below.

# ── Docker image registry ──────────────────────────────────────────────────
GHCR_OWNER=your-github-username
IMAGE_TAG=latest

# ── Caddy / domain ────────────────────────────────────────────────────────
SITE_DOMAIN=localhost
ACME_EMAIL=

# ── Django core ────────────────────────────────────────────────────────────
DJANGO_DEBUG=false
DJANGO_SECRET_KEY=change-me
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ── Auth / tokens ──────────────────────────────────────────────────────────
JWT_SIGNING_KEY=change-me
TOKEN_HASH_KEY=change-me
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000

# ── Channel config encryption (Fernet key) ─────────────────────────────────
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CHANNEL_CONFIG_ENCRYPTION_KEY=

# ── Frontend URL (used in verification/reset email links) ──────────────────
APP_BASE_URL=https://localhost

# ── CORS ───────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=https://localhost

# ── Feature flags ──────────────────────────────────────────────────────────
ALLOW_USER_SIGNUP=true
REQUIRE_VERIFIED_EMAIL_FOR_INGEST=true

# ── Gunicorn ───────────────────────────────────────────────────────────────
WEB_CONCURRENCY=2

# ── SMTP (optional — leave blank to disable email sending) ─────────────────
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=true
DEFAULT_FROM_EMAIL=no-reply@localhost
