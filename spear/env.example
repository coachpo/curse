# ---- Required secrets (set strong random values before production use) ----
DJANGO_SECRET_KEY=replace-with-a-random-string
JWT_SIGNING_KEY=replace-with-a-random-string
TOKEN_HASH_KEY=replace-with-a-random-string
CHANNEL_CONFIG_ENCRYPTION_KEY=replace-with-a-urlsafe-base64-32-byte-key

# ---- Runtime ----
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
APP_BASE_URL=http://localhost:8081
CORS_ALLOWED_ORIGINS=http://localhost:8081

# Shared SQLite DB file in the Docker volume.
DATABASE_URL=sqlite:////data/db.sqlite3
SQLITE_TIMEOUT_SECONDS=30

# ---- Auth/session ----
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000

# ---- Feature flags ----
ALLOW_USER_SIGNUP=true
REQUIRE_VERIFIED_EMAIL_FOR_INGEST=true

# ---- Ingest/delivery ----
MAX_INGEST_BYTES=1048576
DELIVERY_MAX_ATTEMPTS=10
DELIVERY_BACKOFF_BASE_SECONDS=5
DELIVERY_BACKOFF_MAX_SECONDS=1800

# ---- Outbound safety/timeouts ----
BARK_REQUEST_TIMEOUT_SECONDS=5
BARK_BLOCK_PRIVATE_NETWORKS=true
NTFY_REQUEST_TIMEOUT_SECONDS=5
NTFY_BLOCK_PRIVATE_NETWORKS=true
MQTT_SOCKET_TIMEOUT_SECONDS=5
MQTT_BLOCK_PRIVATE_NETWORKS=true

# ---- SMTP (optional) ----
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=true
DEFAULT_FROM_EMAIL=no-reply@localhost
