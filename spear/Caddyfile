# Caddyfile — Beacon Spear reverse proxy
#
# Replace {$SITE_DOMAIN} with your domain, or set it in .env.
# For local dev without a domain, replace the site address with ":80".

{
	email {$ACME_EMAIL:}
}

{$SITE_DOMAIN:localhost} {
	# Django API + health check + admin
	handle /api/* {
		reverse_proxy backend:8100
	}

	handle /healthz {
		reverse_proxy backend:8100
	}

	handle /admin/* {
		reverse_proxy backend:8100
	}

	# Django static files (admin CSS/JS)
	handle /static/* {
		reverse_proxy backend:8100
	}

	# React SPA (catch-all)
	handle {
		reverse_proxy frontend:3100
	}

	encode gzip zstd

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}

	log {
		output stdout
		format json
	}
}
