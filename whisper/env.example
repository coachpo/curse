# Host port exposed by reverse proxy (host:container -> WHISPER_PORT:80)
WHISPER_PORT=8085

# Build targets (optional overrides)
BACKEND_IMAGE=last-whisper-backend:prod
FRONTEND_IMAGE=last-whisper-frontend:prod

# Backend runtime configuration
BACKEND_LOG_LEVEL=info
BACKEND_CORS_ORIGINS=http://localhost:8085
BACKEND_DATABASE_URL=sqlite:///data/dictation.db
BACKEND_TTS_PROVIDER=google
BACKEND_TTS_SUPPORTED_LANGUAGES=["fi"]

# API key settings:
# - BACKEND_API_KEYS_CSV is enforced by backend in production.
# - FRONTEND_NEXT_PUBLIC_API_KEY is baked into frontend at build time.
# Keep them aligned.
BACKEND_API_KEYS_CSV=replace-with-a-long-random-key
FRONTEND_NEXT_PUBLIC_API_KEY=replace-with-a-long-random-key

# Frontend build-time public config
FRONTEND_NEXT_PUBLIC_API_URL=/apis
FRONTEND_NEXT_PUBLIC_DEBUG_LOGGING=false

# Google Cloud credentials JSON for backend TTS
# Place your file at deployment/secrets/google-credentials.json
GOOGLE_APPLICATION_CREDENTIALS_FILE=./secrets/google-credentials.json
