# Prism A deployment env
# Copy this file to backend.env in the prism-a/ directory before deployment.

# Public HTTP port exposed by the reverse-proxy container.
PRISM_A_PORT=8087

# Backend runtime settings (from backend/app/core/config.py)
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info

# Backend PostgreSQL DSN (must match your compose/service credentials)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/prism_v1

# Required secrets (replace with strong random values for production)
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
JWT_SECRET=change-me-with-strong-random-value
OTP_HMAC_SECRET=change-me-with-strong-random-value
API_KEY_HASH_SECRET=change-me-with-strong-random-value
PROFILE_ENCRYPTION_SECRET=change-me-with-strong-random-value

# Never return OTP codes in API responses outside local debugging
OTP_DEBUG_RETURN_CODE=false

# Passkey/WebAuthn settings
# Use your real public domain and HTTPS origin in production.
PASSKEY_RP_ID=localhost
PASSKEY_RP_NAME=Prism A
PASSKEY_ORIGIN=http://localhost:3000

# SMTP settings (required for real OTP email delivery)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@prism-a.local
SMTP_USE_TLS=true
