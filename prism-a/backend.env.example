# Prism A compose-time env
# Copy this file to backend.env in the prism-a/ directory before deployment.

# Public HTTP port exposed by the reverse-proxy container.
PRISM_A_PORT=8087

# Backend startup settings now live in prism-a/prism-config/config.json.
# Copy prism-a/config.json.example to prism-a/prism-config/config.json and edit the bootstrap JSON there.
