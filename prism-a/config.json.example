{
  "meta": {
    "schemaVersion": 1,
    "revision": 1,
    "createdAt": "2026-04-27T00:00:00Z",
    "updatedAt": "2026-04-27T00:00:00Z"
  },
  "server": {
    "host": "0.0.0.0",
    "port": 8000,
    "docsEnabled": false
  },
  "database": {
    "url": "postgres://postgres:postgres@postgres:5432/prism_v1?sslmode=disable",
    "runtimePool": {
      "maxConns": 4,
      "minIdleConns": 1
    },
    "managementPool": {
      "maxConns": 12,
      "minIdleConns": 0
    },
    "managementAdmission": {
      "m2MaxConcurrent": 6,
      "m3MaxConcurrent": 2
    }
  },
  "runtime": {
    "bufferingMode": "buffered",
    "secretEncryptionKey": "replace-with-a-long-random-runtime-secret",
    "transport": {
      "maxIdleConns": 100,
      "maxIdleConnsPerHost": 8,
      "maxConnsPerHost": 0,
      "idleConnTimeout": "90s",
      "responseHeaderTimeout": "0s",
      "tlsHandshakeTimeout": "10s",
      "expectContinueTimeout": "1s"
    }
  },
  "http": {
    "corsAllowedOrigins": [
      "http://localhost:8087",
      "http://127.0.0.1:8087"
    ]
  },
  "auth": {
    "jwtSigningKey": "replace-with-a-long-random-jwt-secret",
    "accessTokenTtlSeconds": 900,
    "refreshTokenTtlSeconds": 604800,
    "resetCodeTtlSeconds": 600,
    "accessCookieName": "prism_access_token",
    "refreshCookieName": "prism_refresh_token",
    "cookieSecure": false
  },
  "stateTransfer": {
    "bundleEncryptionKey": "replace-with-a-long-random-bundle-secret"
  }
}
