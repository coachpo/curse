# Prism B deployment env
# Copy this file to backend.env in the prism-b/ directory before deployment.

# Public HTTP port exposed by the reverse-proxy container.
PRISM_B_PORT=8088

# Backend PostgreSQL DSN (must match your compose/service credentials).
# Use a Go-compatible PostgreSQL DSN, not the retired asyncpg format.
DATABASE_URL=postgres://postgres:postgres@postgres:5432/prism_v1

# Backend runtime settings (current Go backend runtime)
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info
APP_ENV=production
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Upstream request timeouts
CONNECT_TIMEOUT=60.0
READ_TIMEOUT=240.0
WRITE_TIMEOUT=120.0

# Optional runtime upstream transport tuning (Go duration syntax for timeouts)
# RUNTIME_TRANSPORT_MAX_IDLE_CONNS=100
# RUNTIME_TRANSPORT_MAX_IDLE_CONNS_PER_HOST=8
# RUNTIME_TRANSPORT_MAX_CONNS_PER_HOST=0
# RUNTIME_TRANSPORT_IDLE_CONN_TIMEOUT=90s
# RUNTIME_TRANSPORT_RESPONSE_HEADER_TIMEOUT=0s
# RUNTIME_TRANSPORT_TLS_HANDSHAKE_TIMEOUT=10s
# RUNTIME_TRANSPORT_EXPECT_CONTINUE_TIMEOUT=1s

# Authentication and secret protection
AUTH_JWT_SECRET=replace-with-a-long-random-jwt-secret
SECRET_ENCRYPTION_KEY=replace-with-a-long-random-encryption-key
# Optional config-bundle encryption key for profile/vendor export-import bundles.
# When unset, Prism falls back to SECRET_ENCRYPTION_KEY.
CONFIG_BUNDLE_ENCRYPTION_KEY=replace-with-a-long-random-bundle-encryption-key
AUTH_ACCESS_TOKEN_TTL_SECONDS=900
AUTH_REFRESH_TOKEN_TTL_SECONDS=604800
AUTH_RESET_CODE_TTL_SECONDS=600
AUTH_COOKIE_NAME=prism_access_token
AUTH_REFRESH_COOKIE_NAME=prism_refresh_token
AUTH_COOKIE_SECURE=false
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME="Prism LLM Gateway"
WEBAUTHN_ORIGIN=http://localhost:5173

# SMTP for email verification and password reset OTP
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=your-smtp-username
SMTP_PASSWORD=your-smtp-password
SMTP_SENDER_EMAIL=no-reply@example.com
SMTP_SENDER_NAME=Prism
SMTP_USE_TLS=true
