# Prism B compose-time env
# Copy this file to backend.env in the prism-b/ directory before deployment.

# Public HTTP port exposed by the reverse-proxy container.
PRISM_B_PORT=8088

# Public PostgreSQL port exposed by the postgres container.
PRISM_B_POSTGRES_PORT=8432

# Backend startup settings now live in prism-b/prism-config/config.json.
# Copy prism-b/config.json.example to prism-b/prism-config/config.json and edit the bootstrap JSON there.
