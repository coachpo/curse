# Host port for Kiro
KIRO_PORT=8092

# Repo-local cache directory persisted into the container.
KIRO_GATEWAY_CACHE_DIR=./state/cache

# Repo-local placeholder token file mounted into the gateway's internal credentials path.
KIRO_GATEWAY_AUTH_TOKEN_FILE=./state/kiro-auth-token.json

# Required: shared secret clients must send as the gateway API key.
PROXY_API_KEY="replace-with-a-long-random-secret"
