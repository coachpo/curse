# Copy this file to deployment/.env and customize values for your environment.

# Public port exposed by the reverse proxy (host:container SWIPERFLIX_PORT:80)
SWIPERFLIX_PORT=8084

# Public origin used by the frontend bundle to call the backend through proxy.
# Match this with the public proxy address and port.
FRONTEND_API_BASE_URL=http://localhost:8084
FRONTEND_API_BEARER_TOKEN=this-is-the-key-for-local-dev

# Backend/OpenList settings
# For Linux hosts, keep host.docker.internal and the compose file will map it.
OPENLIST_API_BASE_URL=http://host.docker.internal:5244
OPENLIST_DIR_PATH=/
OPENLIST_PASSWORD=
OPENLIST_TOKEN=
OPENLIST_USERNAME=
OPENLIST_USER_PASSWORD=
OPENLIST_PUBLIC_BASE_URL=

# Persist SQLite DB to Docker volume mounted at /data
DATABASE_URL=sqlite:////data/swiperflix.db
