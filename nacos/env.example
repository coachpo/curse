# Nacos auth keys (required since Nacos 2.2.1)
# NACOS_AUTH_TOKEN must be a Base64-encoded string of at least 32 characters.
NACOS_AUTH_IDENTITY_KEY=serverIdentity
NACOS_AUTH_IDENTITY_VALUE=security
NACOS_AUTH_TOKEN=VGhpc0lzTXlDdXN0b21TZWNyZXRLZXkwMTIzNDU2Nzg=

# Optional port overrides (defaults in compose.yml)
# NACOS_CONSOLE_PORT=8090
# NACOS_SERVER_PORT=8848
# NACOS_GRPC_PORT=9848
